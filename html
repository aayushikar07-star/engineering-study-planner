<!DOCTYPE html>
<html>

<head>
<title>Engineering Study Planner</title>

<style>

body{
font-family:Arial;
background:linear-gradient(135deg,#141E30,#243B55);
color:white;
text-align:center;
padding:30px;
}

.container{
background:white;
color:black;
width:550px;
margin:auto;
padding:30px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

input{
padding:10px;
width:65%;
border-radius:6px;
border:1px solid gray;
}

button{
padding:10px 15px;
background:#007BFF;
color:white;
border:none;
border-radius:6px;
cursor:pointer;
}

button:hover{
opacity:0.9;
}

.task{
display:flex;
justify-content:space-between;
background:#eee;
margin-top:10px;
padding:8px;
border-radius:6px;
}

/* circular timer */

.circle{
position:relative;
width:200px;
height:200px;
margin:30px auto;
}

svg{
transform:rotate(-90deg);
}

circle{
fill:none;
stroke-width:10;
stroke-linecap:round;
}

.bg{
stroke:#ddd;
}

.progress{
stroke:#4CAF50;
stroke-dasharray:565;
stroke-dashoffset:565;
transition:stroke-dashoffset 1s linear;
}

#time{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
font-size:28px;
font-weight:bold;
}

/* celebration popup */

#celebration{
display:none;
position:fixed;
top:50%;
left:50%;
transform:translate(-50%,-50%);
background:#4CAF50;
color:white;
padding:25px 40px;
font-size:22px;
border-radius:12px;
animation:pop 0.5s ease;
}

@keyframes pop{
0%{transform:translate(-50%,-50%) scale(0.6);opacity:0;}
100%{transform:translate(-50%,-50%) scale(1);opacity:1;}
}

</style>

</head>

<body>

<h1>⚡ Engineering Study Planner</h1>

<div class="container">

<h2>Add Study Task</h2>

<form method="POST">
<input type="text" name="task" placeholder="Enter study task">
<button type="submit">Add</button>
</form>

<h2>Your Tasks</h2>

{% for task in tasks %}

<div class="task">

<span>{{task}}</span>

<button onclick="completeTask({{loop.index0}})">✅ Done</button>

</div>

{% endfor %}

<h2>Pomodoro Timer</h2>

<div class="circle">

<svg width="200" height="200">

<circle class="bg" cx="100" cy="100" r="90"></circle>

<circle class="progress" id="progressCircle" cx="100" cy="100" r="90"></circle>

</svg>

<div id="time">25:00</div>

</div>

<button onclick="startTimer()">Start</button>
<button onclick="resetTimer()">Reset</button>

</div>

<div id="celebration">
🎉 Hurray! Task Completed!
</div>

<script>

let totalTime = 1500
let time = totalTime
let timer

const circumference = 2 * Math.PI * 90

const circle = document.getElementById("progressCircle")

circle.style.strokeDasharray = circumference
circle.style.strokeDashoffset = circumference

function startTimer(){

timer = setInterval(function(){

let m = Math.floor(time/60)
let s = time%60

if(s<10){s="0"+s}

document.getElementById("time").innerHTML = m+":"+s

let progress = (totalTime - time) / totalTime

circle.style.strokeDashoffset = circumference - progress * circumference

time--

if(time < 0){

clearInterval(timer)

document.getElementById("celebration").style.display="block"

setTimeout(function(){
document.getElementById("celebration").style.display="none"
},2000)

}

},1000)

}

function resetTimer(){

clearInterval(timer)

time = totalTime

document.getElementById("time").innerHTML="25:00"

circle.style.strokeDashoffset = circumference

}

function completeTask(id){

let msg=document.getElementById("celebration")

msg.style.display="block"

setTimeout(function(){

window.location.href="/complete/"+id

},1200)

}

</script>

</body>
</html>
